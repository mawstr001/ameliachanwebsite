<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<%- include('partials/seo', {
  seoTitle: 'Bio — Amelia Chan | Violinist & Educator',
  seoDesc:  'Amelia Chan is a violinist whose playing has been called the vibrant soul of the ensemble — an artist who leads from the concertmaster\'s chair and teaches from first principles.',
  seoPath:  '/bio',
  seoJsonLd: {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Amelia Chan',
    url: (siteUrl || 'https://ameliachanviolin.com') + '/bio',
    jobTitle: 'Violinist, Concertmaster & Educator',
    description: 'Amelia Chan is a violinist, concertmaster, and creator of the First Principles Violin teaching system.',
    sameAs: [site.instagram, site.facebook],
    knowsAbout: ['Violin', 'Biomechanics', 'Music Education', 'Chamber Music'],
    alumniOf: { '@type': 'CollegeOrUniversity', name: 'Manhattan School of Music' }
  }
}) %>
<link rel="stylesheet" href="/styles.css" />
<% if (isAdmin) { %><link rel="stylesheet" href="/admin-bar.css" /><% } %>
</head>
<body data-screen-label="Bio"<% if (isAdmin) { %> data-admin-mode<% } %>>

<%- include('partials/nav', { site, page }) %>

<main>

<!-- ============================ BIO INTRO ============================ -->
<section class="band">
  <div class="wrap">
    <div class="sec-head reveal" style="margin-bottom:0">
      <div class="sec-title-wrap">
        <div class="label" data-edit="bio.sectionNum"><%= bio.sectionNum %></div>
        <h2 class="h-section" style="margin-top:14px" data-edit="bio.heading"><%= bio.heading %></h2>
      </div>
      <div class="eyebrow" data-edit="bio.subheading"><%= bio.subheading %></div>
    </div>
  </div>
  <div class="wrap" style="margin-top:52px">
    <div class="bio-grid reveal">
      <div class="bio-body">
        <p data-edit="bio.introPara1"><%= bio.introPara1 %></p>
        <p data-edit="bio.introPara2"><%= bio.introPara2 %></p>
        <p data-edit="bio.teacherPara1"><%= bio.teacherPara1 %></p>
      </div>
      <div>
        <div class="figure portrait">
          <image-slot id="bio-portrait" placeholder="Drop portrait — violinist"
            src="<%= bio.portraitImage %>" data-edit-image="bio.portraitImage"></image-slot>
        </div>
        <div class="scroll-cue" aria-hidden="true">
          <span>Scroll</span>
          <span class="scroll-cue-arrow">&darr;</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================ PRESS ============================ -->
<section class="band alt">
  <div class="wrap">
    <%
      var allPress = press.slice(0, 3);
      function highlightQuote(q) {
        if (!q.highlight) return q.quote;
        return q.quote.replace(q.highlight, '<mark>' + q.highlight + '</mark>');
      }
    %>
    <div class="press-row">
      <% allPress.forEach(function(q) { %>
      <figure class="press-quote reveal">
        <blockquote><%- highlightQuote(q) %></blockquote>
        <figcaption><%= q.source %></figcaption>
      </figure>
      <% }); %>
    </div>
  </div>
</section>

</main>

<%- include('partials/footer', { site }) %>

<script src="/image-slot.js"></script>
<script src="/site.js"></script>
<% if (isAdmin) { %><script src="/admin-bar.js"></script><% } %>
</body>
</html>
