<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>First Principles Violin — Amelia Chan</title>
<link rel="stylesheet" href="/styles.css" />
<% if (isAdmin) { %><link rel="stylesheet" href="/admin-bar.css" /><% } %>
</head>
<body data-screen-label="First Principles"<% if (isAdmin) { %> data-admin-mode<% } %>>

<%- include('partials/nav', { site, page }) %>

<main>

<!-- ============================ THE METHOD ============================ -->
<section class="band">
  <div class="wrap">
    <div class="method reveal">
      <div>
        <div class="label" data-edit="firstPrinciples.sectionNum"><%= fp.sectionNum %></div>
        <h2 class="h-section" style="margin-top:14px" data-edit="firstPrinciples.heading"><%= fp.heading %></h2>
        <ol class="principles" style="margin-top:44px">
          <li>
            <span class="n">1</span>
            <div>
              <h3 data-edit="firstPrinciples.method1Label"><%= fp.method1Label || 'Biomechanics in Action' %></h3>
              <p data-edit="firstPrinciples.method1Desc"><%= fp.method1Desc || 'Optimise every movement and posture for efficiency and power — reducing tension and preventing injury.' %></p>
            </div>
          </li>
          <li>
            <span class="n">2</span>
            <div>
              <h3 data-edit="firstPrinciples.method2Label"><%= fp.method2Label || 'Fundamental Acoustics' %></h3>
              <p data-edit="firstPrinciples.method2Desc"><%= fp.method2Desc || 'The science of sound production: how string, wood, and bow pressure create true intonation and tone.' %></p>
            </div>
          </li>
          <li>
            <span class="n">3</span>
            <div>
              <h3 data-edit="firstPrinciples.method3Label"><%= fp.method3Label || 'Mental Cognition' %></h3>
              <p data-edit="firstPrinciples.method3Desc"><%= fp.method3Desc || 'Score analysis, mental mapping, and focus that ensure consistent, expressive performance.' %></p>
            </div>
          </li>
        </ol>
        <a class="btn method-cta" href="/writings">Read the Methodology</a>
      </div>
      <div class="colorblocks" aria-hidden="true">
        <div class="cb-ox"></div>
        <div class="cb-gd"></div>
        <div class="cb-nv"></div>
      </div>
    </div>
  </div>
</section>

<!-- ============================ WRITINGS TEASER ============================ -->
<section class="band alt tight">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-title-wrap">
        <div class="label">From the Writings</div>
        <h2 class="h-section" data-edit="firstPrinciples.writingsTeaserHeading"><%= fp.writingsTeaserHeading || 'The principles, in essays.' %></h2>
      </div>
      <a class="linkcta" href="/writings">All writings &rarr;</a>
    </div>
    <div class="writings-list reveal">
      <% writings.slice(0, 3).forEach(function(w) { %>
      <a class="wr" href="<%= w.slug ? '/writings/' + w.slug : w.link %>">
        <span class="wn">№ <%= w.number %></span>
        <span class="wt"><%- w.title %></span>
        <span class="wm"><%= w.category %> <span class="arrow">&rarr;</span></span>
      </a>
      <% }); %>
    </div>
  </div>
</section>

</main>

<%- include('partials/footer', { site }) %>

<script src="/image-slot.js"></script>
<script src="/site.js"></script>
<% if (isAdmin) { %><script src="/admin-bar.js"></script><% } %>
</body>
</html>
