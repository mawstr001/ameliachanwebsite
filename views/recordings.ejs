<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Recordings — Amelia Chan</title>
<link rel="stylesheet" href="/styles.css" />
<% if (isAdmin) { %><link rel="stylesheet" href="/admin-bar.css" /><% } %>
</head>
<body data-screen-label="Recordings"<% if (isAdmin) { %> data-admin-mode<% } %>>

<%- include('partials/nav', { site, page }) %>

<main>

<!-- ============================ RECORDINGS ============================ -->
<section class="band">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-title-wrap">
        <div class="num">Recordings</div>
        <h2 class="h-section" style="margin-top:18px">Selected<br />performances.</h2>
      </div>
      <div class="eyebrow">Hover to bring each to life</div>
    </div>

    <div class="rec-grid reveal">
      <% recordings.forEach(function(rec, i) { %>
      <div class="rec">
        <div class="rec-plate">
          <div class="filtered">
            <image-slot id="rec-<%= i+1 %>" style="width:100%;height:100%"
              placeholder="Drop cover art" src="<%= rec.image %>" data-edit-image="recordings[<%= i %>].image"></image-slot>
          </div>
          <div class="play">
            <span class="disc">
              <svg width="14" height="14" viewBox="0 0 14 14"><path d="M2 1 L12 7 L2 13 Z" fill="currentColor"/></svg>
            </span>
          </div>
        </div>
        <div class="rec-meta">
          <div class="rt" data-edit="recordings[<%= i %>].title"><%= rec.title %></div>
          <div class="rm" data-edit="recordings[<%= i %>].ensemble"><%= rec.ensemble %></div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

</main>

<%- include('partials/footer', { site, footerBig: "Let's make<br />something <a href=\"mailto:" + site.email + "\">resonate.</a>", footerBigKey: '' }) %>

<script src="/image-slot.js"></script>
<script src="/site.js"></script>
<% if (isAdmin) { %><script src="/admin-bar.js"></script><% } %>
</body>
</html>
