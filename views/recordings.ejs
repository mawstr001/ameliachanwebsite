<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<%- include('partials/seo', {
  seoTitle: 'Recordings — Amelia Chan | Selected Performances',
  seoDesc:  'Selected recordings by violinist Amelia Chan — including Saygun and Kai-young Chan performances.',
  seoPath:  '/recordings',
  seoJsonLd: {
    '@context': 'https://schema.org',
    '@type': 'MusicPlaylist',
    name: 'Selected Recordings — Amelia Chan',
    description: 'Selected violin performances by Amelia Chan.',
    url: (siteUrl || 'https://ameliachanviolin.com') + '/recordings',
    byArtist: { '@type': 'Person', name: 'Amelia Chan' }
  }
}) %>
<link rel="stylesheet" href="/styles.css" />
<% if (isAdmin) { %><link rel="stylesheet" href="/admin-bar.css" /><% } %>
</head>
<body data-screen-label="Recordings"<% if (isAdmin) { %> data-admin-mode<% } %>>

<%- include('partials/nav', { site, page }) %>

<main>

<!-- ============================ RECORDINGS ============================ -->
<section class="band">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-title-wrap">
        <div class="label">Recordings</div>
        <h2 class="h-section">Selected performances.</h2>
      </div>
      <div class="eyebrow">Hover to play</div>
    </div>

    <div class="rec-grid reveal">
      <% recordings.forEach(function(rec, i) { %>
      <div class="rec">
        <div class="rec-plate">
          <image-slot id="rec-<%= i+1 %>" placeholder="Drop cover art"
            src="<%= rec.image %>" data-edit-image="recordings[<%= i %>].image"></image-slot>
          <% if (rec.link && rec.link !== '#') { %>
          <a class="play" href="<%= rec.link %>" target="_blank" rel="noopener" aria-label="Watch on YouTube">
            <span class="disc"><svg width="15" height="15" viewBox="0 0 14 14"><path d="M2 1 L12 7 L2 13 Z"/></svg></span>
          </a>
          <% } else { %>
          <div class="play">
            <span class="disc"><svg width="15" height="15" viewBox="0 0 14 14"><path d="M2 1 L12 7 L2 13 Z"/></svg></span>
          </div>
          <% } %>
        </div>
        <div class="rec-meta">
          <div class="rt" data-edit="recordings[<%= i %>].title"><%= rec.title %></div>
          <div class="rm" data-edit="recordings[<%= i %>].ensemble"><%= rec.ensemble %></div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

</main>

<%- include('partials/footer', { site }) %>

<script src="/image-slot.js"></script>
<script src="/site.js"></script>
<% if (isAdmin) { %><script src="/admin-bar.js"></script><% } %>
</body>
</html>
