<footer class="footer" id="contact">
  <div class="foot-inner">
    <div class="foot-mark">Amelia Chan<span>First Principles Violin</span></div>
    <h2 class="foot-h">Refine Your Technique</h2>
    <p class="foot-p">Join the email list for biomechanical insights and educational resources.</p>
    <form class="subscribe" onsubmit="return false">
      <input type="email" placeholder="Enter your email address" aria-label="Email address" />
      <button type="submit">Subscribe</button>
    </form>
    <div class="foot-social">
      <a href="<%= site.instagram %>" target="_blank" rel="noopener">Instagram</a>
      <a href="<%= site.facebook %>" target="_blank" rel="noopener">Facebook</a>
      <a href="mailto:<%= site.email %>">Email</a>
    </div>
    <div class="foot-fine">
      <span><%= site.copyright || '&copy; 2026 Amelia Chan &middot; Violinist' %></span>
      <span>Privacy Policy &middot; Terms of Service</span>
    </div>
  </div>
  <div class="barstrip cap"><i class="ox"></i><i class="gd"></i><i class="nv"></i></div>
</footer>
