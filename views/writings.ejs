<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<%- include('partials/seo', {
  seoTitle: 'Writings — Amelia Chan | First Principles Violin Essays',
  seoDesc:  'Essays on violin technique, biomechanics, musical structure, and practice — written by violinist and educator Amelia Chan.',
  seoPath:  '/writings',
  seoJsonLd: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Writings — Amelia Chan',
    description: 'Essays on violin technique, biomechanics, musical structure, and practice.',
    url: (siteUrl || 'https://ameliachanviolin.com') + '/writings',
    author: { '@type': 'Person', name: 'Amelia Chan' }
  }
}) %>
<link rel="stylesheet" href="/styles.css" />
<% if (isAdmin) { %><link rel="stylesheet" href="/admin-bar.css" /><% } %>
</head>
<body data-screen-label="Writings"<% if (isAdmin) { %> data-admin-mode<% } %>>

<%- include('partials/nav', { site, page }) %>

<main>

<!-- ============================ WRITINGS ============================ -->
<section class="band">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-title-wrap">
        <div class="label">Writings</div>
        <h2 class="h-section">Notes on the first principles.</h2>
      </div>
      <div class="eyebrow">Technique &middot; Structure &middot; Practice</div>
    </div>

    <div class="writings-list reveal">
      <% writings.forEach(function(w) { %>
      <a class="wr" href="<%= w.slug ? '/writings/' + w.slug : w.link %>">
        <span class="wn">№ <%= w.number %></span>
        <span class="wt"><%- w.title %></span>
        <span class="wm"><%= w.category %> <span class="arrow">&rarr;</span></span>
      </a>
      <% }); %>
    </div>
  </div>
</section>

</main>

<%- include('partials/footer', { site }) %>

<script src="/image-slot.js"></script>
<script src="/site.js"></script>
<% if (isAdmin) { %><script src="/admin-bar.js"></script><% } %>
</body>
</html>
