<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Amelia Chan — Violinist · First Principles Violin</title>
<link rel="stylesheet" href="/styles.css" />
<% if (isAdmin) { %><link rel="stylesheet" href="/admin-bar.css" /><% } %>
</head>
<body data-screen-label="Home"<% if (isAdmin) { %> data-admin-mode<% } %>>

<%- include('partials/nav', { site, page }) %>

<main>

<!-- ============================ HERO ============================ -->
<section class="wrap hero">
  <div>
    <div class="label" data-edit="home.left.kicker"><%= home.left.kicker %></div>
    <h1 class="hero-name">Amelia Chan</h1>
    <p class="hero-role" style="font-size:21px" data-edit="home.left.role"><%= home.left.role %></p>
    <p class="hero-lead" data-edit="home.left.blurb"><%= home.left.blurb %></p>
    <a class="btn hero-cta" href="/bio">Read Biography</a>
  </div>
  <div class="figure portrait">
    <image-slot id="hero-portrait" placeholder="Drop portrait — violinist"
      src="<%= home.left.heroImage %>" data-edit-image="home.left.heroImage"></image-slot>
  </div>
</section>

<!-- ============================ THE SYSTEM ============================ -->
<section class="band alt" id="system">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-title-wrap">
        <div class="label">The Method</div>
        <h2 class="h-section" style="display:flex;align-items:center;gap:18px;flex-wrap:wrap">
          <img src="/fp-logo.png" alt="" aria-hidden="true" style="height:62px;width:auto;display:inline-block;vertical-align:middle">
          The First Principles Violin System
        </h2>
      </div>
      <a class="linkcta" href="/first-principles">Explore the method &rarr;</a>
    </div>
    <ol class="principles row reveal">
      <li>
        <div class="n">1</div>
        <h3>Biomechanics</h3>
        <p>Movement optimised for efficiency and power — reducing tension, preventing injury.</p>
      </li>
      <li>
        <div class="n">2</div>
        <h3>Acoustics</h3>
        <p>The science of sound: how string, wood, and bow create true intonation and tone.</p>
      </li>
      <li>
        <div class="n">3</div>
        <h3>Cognition</h3>
        <p>Score analysis and focus that make consistent, expressive performance possible.</p>
      </li>
    </ol>
  </div>
</section>

</main>

<%- include('partials/footer', { site }) %>

<script src="/image-slot.js"></script>
<script src="/site.js"></script>
<% if (isAdmin) { %><script src="/admin-bar.js"></script><% } %>
</body>
</html>
