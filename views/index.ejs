<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Amelia Chan — Violinist · First Principles Violin</title>
<link rel="stylesheet" href="/styles.css" />
<% if (isAdmin) { %><link rel="stylesheet" href="/admin-bar.css" /><% } %>
</head>
<body data-screen-label="Home"<% if (isAdmin) { %> data-admin-mode<% } %>>

<%- include('partials/nav', { site, page }) %>

<!-- ============================ HOME SPLIT ============================ -->
<main class="home">
  <div class="home-split">

    <!-- LEFT — Amelia Chan -->
    <a class="home-panel" href="/bio">
      <div class="home-panel-inner">
        <div class="home-head">
          <div class="kicker" data-edit="home.left.kicker"><%= home.left.kicker %></div>
          <div class="home-name" data-edit="home.left.name"><%= home.left.name %></div>
          <div class="home-role" data-edit="home.left.role"><%= home.left.role %></div>
        </div>

        <div class="plate">
          <span class="bracket tl"></span><span class="bracket tr"></span>
          <span class="bracket bl"></span><span class="bracket br"></span>
          <div class="plate-inner">
            <div class="filtered">
              <image-slot id="hero-portrait" style="width:100%;height:100%"
                placeholder="Drop portrait — violinist" src="<%= home.left.heroImage %>" data-edit-image="home.left.heroImage"></image-slot>
            </div>
            <div class="blueprint">
              <svg viewBox="0 0 100 125" preserveAspectRatio="none" aria-hidden="true">
                <path class="bp-arc" d="M82 16 A 16 16 0 0 1 92 30" />
                <path class="bp-line" d="M16 96 L34 90" /><circle class="bp-dot" cx="34" cy="90" r="1.1" />
                <path class="bp-line" d="M86 70 L72 66" /><circle class="bp-dot" cx="72" cy="66" r="1.1" />
              </svg>
              <div class="bp-label" style="top:31%;left:4%">
                <div class="bp-k" data-edit="home.left.bp1Key"><%= home.left.bp1Key %></div>
                <div class="bp-s" data-edit="home.left.bp1Sub"><%= home.left.bp1Sub %></div>
              </div>
              <div class="bp-label" style="top:70%;left:4%">
                <div class="bp-k" data-edit="home.left.bp2Key"><%= home.left.bp2Key %></div>
                <div class="bp-s" data-edit="home.left.bp2Sub"><%= home.left.bp2Sub %></div>
              </div>
            </div>
            <div class="fig-cap" data-edit="home.left.figCaption"><%= home.left.figCaption %></div>
          </div>
        </div>

        <div class="home-text">
          <p class="home-blurb" data-edit="home.left.blurb"><%= home.left.blurb %></p>
          <div class="home-quote">
            <p data-edit="home.left.quoteText">"<%= home.left.quoteText %>"</p>
            <span class="src" data-edit="home.left.quoteSource">— <%= home.left.quoteSource %></span>
          </div>
          <span class="enter" data-edit="home.left.cta"><%= home.left.cta %> <span class="ar">→</span></span>
        </div>
      </div>
    </a>

    <!-- DIVIDER -->
    <div class="home-divider" aria-hidden="true">
      <svg class="home-divider-line" viewBox="0 0 96 1000" preserveAspectRatio="none">
        <path d="M58 0 C 30 260, 70 460, 44 640 C 24 800, 60 900, 40 1000" />
      </svg>
      <div class="compass">
        <svg viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="9" stroke="#2f6f8f" stroke-width="1"/>
          <path d="M12 5 L14 12 L12 19 L10 12 Z" fill="#2f6f8f"/>
          <circle cx="12" cy="12" r="1.3" fill="#1b1a16"/>
        </svg>
      </div>
    </div>

    <!-- RIGHT — First Principles Violin -->
    <a class="home-panel" href="/first-principles">
      <div class="home-panel-inner">
        <div class="home-head">
          <div class="kicker" data-edit="home.right.kicker"><%= home.right.kicker %></div>
          <div class="home-name" data-edit="home.right.name"><%= home.right.name %></div>
          <div class="home-role" data-edit="home.right.role"><%= home.right.role %></div>
        </div>

        <div class="plate">
          <span class="bracket tl"></span><span class="bracket tr"></span>
          <span class="bracket bl"></span><span class="bracket br"></span>
          <div class="plate-inner">
            <div class="filtered">
              <image-slot id="hero-system" style="width:100%;height:100%"
                placeholder="Drop study — violin structure" src="<%= home.right.systemImage %>" data-edit-image="home.right.systemImage"></image-slot>
            </div>
            <div class="blueprint">
              <svg viewBox="0 0 100 125" preserveAspectRatio="none" aria-hidden="true">
                <circle class="bp-arc" cx="78" cy="92" r="13" />
                <path class="bp-line" d="M65 92 L40 80" /><circle class="bp-dot" cx="40" cy="80" r="1.1" />
                <path class="bp-line" d="M30 30 L48 44" /><circle class="bp-dot" cx="48" cy="44" r="1.1" />
              </svg>
              <div class="bp-label" style="top:18%;left:5%">
                <div class="bp-k" data-edit="home.right.bp1Key"><%= home.right.bp1Key %></div>
                <div class="bp-s" data-edit="home.right.bp1Sub"><%= home.right.bp1Sub %></div>
              </div>
              <div class="bp-label" style="top:80%;right:5%;text-align:right">
                <div class="bp-k" data-edit="home.right.bp2Key"><%= home.right.bp2Key %></div>
                <div class="bp-s" data-edit="home.right.bp2Sub"><%= home.right.bp2Sub %></div>
              </div>
            </div>
            <div class="fig-cap" data-edit="home.right.figCaption"><%= home.right.figCaption %></div>
          </div>
        </div>

        <div class="home-text">
          <p class="home-blurb" data-edit="home.right.blurb"><%= home.right.blurb %></p>
          <div class="home-principle">
            <div class="pl" data-edit="home.right.principleLabel"><%= home.right.principleLabel %></div>
            <p data-edit="home.right.principleText"><%= home.right.principleText %></p>
          </div>
          <span class="enter" data-edit="home.right.cta"><%= home.right.cta %> <span class="ar">→</span></span>
        </div>
      </div>
    </a>

  </div>
</main>

<script src="/image-slot.js"></script>
<script src="/site.js"></script>
<% if (isAdmin) { %><script src="/admin-bar.js"></script><% } %>
</body>
</html>
